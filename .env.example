# Copy to .env and fill in. NEVER commit .env (covered by .gitignore).

# BaseScan/Etherscan API key for contract source verification
ETHERSCAN_API_KEY=

# Blockscout API key (dev.blockscout.com) — alternative explorer/verification
BLOCKSCOUT_API_KEY=

# Deployer address (public info, convenience only — the private key lives in
# the Foundry encrypted keystore, imported via `cast wallet import`)
DEPLOYER_ADDRESS=0x23ddAAd22d030b4a8d0BFbADeaCA11Ed9959D08C

# Throwaway helper wallet used for the mainnet AMBR lifecycle (transferFrom leg)
HELPER_ADDRESS=
HELPER_PRIVATE_KEY=
